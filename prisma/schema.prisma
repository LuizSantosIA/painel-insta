// Schema do painel de gestão do Instagram.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Um post (ou story) do Instagram com suas métricas.
// SQLite não tem enum nativo, então mediaType/category/source são String.
model Post {
  id           String   @id @default(cuid())
  igId         String?  @unique // id da mídia na Graph API (null = manual)
  caption      String?
  mediaType    String // IMAGE | VIDEO | CAROUSEL_ALBUM | REELS | STORY
  category     String? // tema definido por você: "Dica", "Bastidores", "Promo"...
  permalink    String?
  mediaUrl     String?
  thumbnailUrl String?
  postedAt     DateTime

  // Métricas
  likes           Int @default(0)
  comments        Int @default(0)
  saves           Int @default(0)
  shares          Int @default(0)
  reach           Int @default(0)
  impressions     Int @default(0)
  videoViews      Int @default(0)
  followersAtPost Int @default(0) // seguidores no momento do post (p/ taxa de engajamento)

  source    String   @default("manual") // manual | csv | instagram
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postedAt])
  @@index([mediaType])
  @@index([category])
}

// Snapshot diário da conta para o gráfico de evolução de seguidores.
model AccountSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @unique
  followers Int
  follows   Int      @default(0)
  reach     Int      @default(0)
  createdAt DateTime @default(now())
}

// Regra de automação: quando keyword aparecer num comentário, dispara replyText.
model AutoRule {
  id           String       @id @default(cuid())
  name         String       @default("")
  keywords     String       // palavras-chave separadas por vírgula
  replyText    String       @default("") // resposta pública no comentário (vazio = não responde)
  sendDm       Boolean      @default(false)
  dmText       String       @default("") // texto do direct
  mediaId      String? // id da mídia (igId) à qual a regra se restringe; null = todos os posts
  isActive     Boolean      @default(true)
  triggerCount Int          @default(0)
  createLead   Boolean      @default(false) // se true, cria Lead quando a regra dispara
  leadLinha    String?      // INNOBI | MENTORIA | SERVICOS — obrigatório se createLead=true
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  logs         CommentLog[]

  @@index([mediaId])
}

// Log de cada comentário processado pelas regras.
model CommentLog {
  id          String    @id @default(cuid())
  igCommentId String    @unique
  igPostId    String
  text        String
  username    String    @default("")
  senderId    String    @default("") // IGSID do comentarista (para DM)
  repliedAt   DateTime?
  dmSentAt    DateTime?
  ruleId      String?
  rule        AutoRule? @relation(fields: [ruleId], references: [id])
  createdAt   DateTime  @default(now())
}

// ─── CRM ────────────────────────────────────────────────────────────────────

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  instagram String?
  company   String?
  notes     String?
  status    String    @default("lead") // lead | active | inactive | lost
  source    String?   // instagram | whatsapp | referral | organic | other
  tags      String?   // separadas por vírgula
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deals     Deal[]
  tasks     Task[]
  receitas  Receita[]
}

model Deal {
  id        String    @id @default(cuid())
  title     String
  value     Float     @default(0)
  stage     String    @default("lead") // lead | contacted | proposal | negotiation | won | lost
  notes     String?
  dueDate   DateTime?
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([stage])
  @@index([clientId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  done        Boolean   @default(false)
  priority    String    @default("medium") // low | medium | high
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([done])
  @@index([dueDate])
  @@index([clientId])
}

// ─── Pipeline de Leads ───────────────────────────────────────────────────────

// estagio: LEAD | QUALIFICADO | PROPOSTA_ENVIADA | NEGOCIACAO | FECHADO | PERDIDO
// origem:  INSTAGRAM_DM | INSTAGRAM_COMENTARIO | WHATSAPP | EMAIL | INDICACAO | OUTRO
// linhaInteresse: INNOBI | MENTORIA | SERVICOS
// proximaAcao + proximaAcaoEm: obrigatórios para estágios ativos (validados na API)

model Lead {
  id                    String    @id @default(cuid())
  nome                  String
  contato               String
  estagio               String    @default("LEAD")
  origem                String
  linhaInteresse        String
  valorEstimadoCentavos Int?
  proximaAcao           String?
  proximaAcaoEm         DateTime?
  postOrigemId          String?   // preenchido pela Fase 3
  notas                 String?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  @@index([estagio, proximaAcaoEm])
}

// ─── Financeiro ──────────────────────────────────────────────────────────────

// linha: INNOBI | MENTORIA | SERVICOS
// tipo:  RECORRENTE | PONTUAL
// status: PREVISTA | CONFIRMADA | RECEBIDA | INADIMPLENTE
// SQLite não suporta enum nativo — valores validados na camada de API (Zod).

model Receita {
  id            String    @id @default(cuid())
  descricao     String
  valorCentavos Int       // NUNCA Float — dinheiro sempre em centavos
  linha         String    // INNOBI | MENTORIA | SERVICOS
  tipo          String    // RECORRENTE | PONTUAL
  status        String    @default("PREVISTA")
  clienteId     String?
  cliente       Client?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  competencia   DateTime  // sempre dia 1 do mês, UTC
  dataRecebida  DateTime?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@index([competencia, status])
  @@index([linha])
}

model Despesa {
  id            String   @id @default(cuid())
  descricao     String
  valorCentavos Int
  recorrente    Boolean  @default(false)
  competencia   DateTime // sempre dia 1 do mês, UTC
  criadoEm      DateTime @default(now())

  @@index([competencia])
}

// Configurações globais — singleton (id = "singleton")
model Config {
  id           String   @id @default("singleton")
  saldoCaixa   Int      @default(0) // centavos — informado manualmente
  atualizadoEm DateTime @updatedAt
}